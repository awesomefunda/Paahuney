# ─────────────────────────────────────────────
# Paahuney — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in values:
#   cp .env.local.example .env.local

# ── Supabase (required) ──────────────────────
# Get these from: https://supabase.com → Your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Service Role (only for seeder script) ──
# Never expose this in the browser! Only used in scripts/scrape_seed_data.py
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq API (optional, for AI-powered scraper) ──
# Free tier at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
